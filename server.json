const express = require("express");
const app = express();

app.get("/", (req, res) => {
  res.send("ORAYAN backend running 🚀");
});

app.get("/status", (req, res) => {
  res.json({
    status: "ok",
    time: Date.now()
  });
});

app.listen(3000, () => {
  console.log("Server running on port 3000");
});
